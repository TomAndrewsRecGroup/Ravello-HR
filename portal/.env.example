# ──────────────────────────────────────────────────
# The People System — Client Portal Environment
# ──────────────────────────────────────────────────

# Supabase — add these in Vercel environment variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side operations requiring elevated access
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IvyLens Friction Lens integration (server-side only)
IVYLENS_API_URL=https://api.ivylens.app
IVYLENS_API_KEY=your-ivylens-api-key

# Manatal ATS integration
MANATAL_API_KEY=your-manatal-api-key
MANATAL_API_URL=https://api.manatal.com/open/v1

# Portal URL (used by admin for invite redirects)
NEXT_PUBLIC_PORTAL_URL=https://your-portal-domain.vercel.app

# Stripe (e-learning payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Learning content access window (days, default 7)
LEARNING_ACCESS_DAYS=7
