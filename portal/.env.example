# Supabase — add these in Vercel environment variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — for server-side operations requiring elevated access
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IvyLens Friction Lens integration (server-side only)
IVYLENS_API_URL=https://api.ivylens.app
IVYLENS_API_KEY=your-ivylens-api-key

# Manatal ATS integration
MANATAL_API_KEY=your-manatal-api-key
MANATAL_API_URL=https://api.manatal.com/open/v1

# Portal URL (used by admin for invite redirects)
NEXT_PUBLIC_PORTAL_URL=https://your-portal-domain.vercel.app
